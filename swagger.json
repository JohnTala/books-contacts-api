{
  "swagger": "2.0",
  "info": {
    "title": "Books & Contacts API",
    "description": "API for managing books and contacts collections",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http"],
  "paths": {
    "/books": {
      "get": {
        "tags": ["Books"],
        "summary": "Get all books",
        "responses": {
          "200": { "description": "List of all books" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Books"],
        "summary": "Create a new book",
        "parameters": [
          {
            "in": "body",
            "name": "book",
            "description": "Book object to create",
            "required": true,
            "schema": { "$ref": "#/definitions/Book" }
          }
        ],
        "responses": {
          "201": { "description": "Book created" },
          "400": { "description": "Invalid input" }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "summary": "Get a single book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Single book object" },
          "404": { "description": "Book not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Books"],
        "summary": "Update a book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "in": "body", "name": "book", "required": true, "schema": { "$ref": "#/definitions/Book" } }
        ],
        "responses": {
          "200": { "description": "Book updated" },
          "400": { "description": "Invalid input" },
          "404": { "description": "Book not found" }
        }
      },
      "delete": {
        "tags": ["Books"],
        "summary": "Delete a book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book deleted" },
          "404": { "description": "Book not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get all contacts",
        "responses": {
          "200": { "description": "List of all contacts" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Contacts"],
        "summary": "Create a new contact",
        "parameters": [
          {
            "in": "body",
            "name": "contact",
            "description": "Contact object to create",
            "required": true,
            "schema": { "$ref": "#/definitions/Contact" }
          }
        ],
        "responses": {
          "201": { "description": "Contact created" },
          "400": { "description": "Invalid input" }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get a single contact by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Single contact object" },
          "404": { "description": "Contact not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update a contact by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "in": "body", "name": "contact", "required": true, "schema": { "$ref": "#/definitions/Contact" } }
        ],
        "responses": {
          "200": { "description": "Contact updated" },
          "400": { "description": "Invalid input" },
          "404": { "description": "Contact not found" }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete a contact by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Contact deleted" },
          "404": { "description": "Contact not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  },
  "definitions": {
    "Book": {
      "type": "object",
      "required": ["title", "author", "genre", "year"],
      "properties": {
        "title": { "type": "string", "example": "The Great Gatsby" },
        "author": { "type": "string", "example": "F. Scott Fitzgerald" },
        "genre": { "type": "string", "example": "Classic" },
        "year": { "type": "integer", "example": 1925 }
      }
    },
    "Contact": {
      "type": "object",
      "required": ["firstName", "lastName", "email", "favoriteColor", "birthday"],
      "properties": {
        "firstName": { "type": "string", "example": "John" },
        "lastName": { "type": "string", "example": "Doe" },
        "email": { "type": "string", "example": "john@example.com" },
        "favoriteColor": { "type": "string", "example": "Blue" },
        "birthday": { "type": "string", "format": "date", "example": "1990-01-01" }
      }
    }
  }
}
